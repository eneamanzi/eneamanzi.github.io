---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    {% if page.subtitle %}
      <p class="post-subtitle">{{ page.subtitle }}</p>
    {% endif %}
  </header>

  <article class="post-content">
    {{ content }}
  </article>
</div>

{% if site.enable_medium_zoom %}
  <script>
    $(document).ready(function () {
      $(".post-content img").attr("data-zoomable", "");
      if (typeof medium_zoom !== "undefined") {
        medium_zoom.attach(".post-content img");
      }
    });
  </script>
{% endif %}
